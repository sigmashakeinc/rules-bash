# bash_write_safety.rules
# Technology: bash | Capability: write

rule bash-eval-injection {
  enabled true
  priority 100
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "\\beval\\s+[\"']?\\$"
  MESSAGE "RISK: 'eval' on a variable is a command-injection sink — attacker-controlled input runs with the script's privileges. FIX: avoid 'eval'; use a 'case' dispatch, an associative-array lookup, or arrays (\"${cmd[@]}\") to build commands without re-parsing."
}

rule bash-deprecated-backticks {
  enabled true
  priority 90
  severity warning
  LOG write
  IF path GLOB "**/*.sh" AND content CONTAINS "`"
  MESSAGE "RISK: backtick command substitution is hard to nest, easy to confuse with quotes, and discouraged by the Google Shell Style Guide. FIX: use the modern '$(command)' form, which nests cleanly and is unambiguous."
}

rule bash-unquoted-for-loop-variable {
  enabled true
  priority 85
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "\\bfor\\s+[a-zA-Z_][a-zA-Z0-9_]*\\s+in\\s+\\$[a-zA-Z_]"
  MESSAGE "RISK: 'for f in $VAR' triggers word-splitting and pathname expansion, so the loop iterates over unintended tokens or matched files (ShellCheck SC2066/SC2086). FIX: quote ('for f in \"$VAR\"') or, for lists, iterate over an array with 'for f in \"${arr[@]}\"'."
}

rule bash-insecure-mktemp-no-template {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "\\bmktemp\\s+(-[dt]\\s+)?(/tmp/|/var/tmp/)[a-zA-Z0-9_.-]+\\s*$"
  MESSAGE "RISK: 'mktemp /tmp/fixed-name' (no XXXXXX template) is predictable and vulnerable to symlink/TOCTOU races on shared systems. FIX: pass a template with at least six trailing X's, e.g. 'mktemp /tmp/myapp.XXXXXXXX' or 'mktemp -d -t myapp.XXXXXXXX'."
}

rule bash-echo-variable-output {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "\\becho\\s+[\"']?-?\\$[a-zA-Z_]"
  MESSAGE "RISK: 'echo $VAR' misinterprets leading dashes as flags and processes backslash escapes inconsistently across shells (Google Shell Style Guide). FIX: use 'printf %s\\n \"$VAR\"' for predictable, portable output."
}

rule bash-sudo-arbitrary-shell {
  enabled true
  priority 98
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "\\bsudo\\s+(-[A-Za-z]+\\s+)*(bash|sh|zsh|/bin/bash|/bin/sh|/bin/zsh)\\b"
  MESSAGE "RISK: 'sudo bash' (or 'sudo sh') grants root to an interactive/arbitrary shell, bypassing any sudoers command restrictions. FIX: invoke the specific binary with explicit arguments under sudo, and pin the allowed commands in /etc/sudoers."
}

rule bash-curl-insecure-tls {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "\\b(curl|wget)\\b[^#\\n]*\\s(-k|--insecure|--no-check-certificate)\\b"
  MESSAGE "RISK: disabling TLS verification (curl -k / wget --no-check-certificate) enables MITM tampering — exactly the supply-chain vector behind incidents like xz CVE-2024-3094 and curl CVE-2024-7264. FIX: remove the flag; if a custom CA is needed, pass it explicitly with '--cacert /path/to/ca.pem'."
}

rule bash-source-variable-path {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "^\\s*(source|\\.)\\s+[\"']?\\$[a-zA-Z_]"
  MESSAGE "RISK: sourcing a variable path ('source $FILE') loads arbitrary code into the current shell — attacker control of the variable means RCE with the script's privileges. FIX: hard-code the path, validate against a strict allowlist before sourcing, and always quote ('source \"$FILE\"')."
}

rule bash-rm-rf-trailing-slash-var {
  enabled true
  priority 100
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "\\brm\\s+-[rRfF]+[a-zA-Z]*\\s+[\"']?\\$\\{?[a-zA-Z_][a-zA-Z0-9_]*\\}?/"
  MESSAGE "RISK: 'rm -rf \"$dir/\"' wipes the filesystem root if $dir is empty or unset (ShellCheck SC2115). FIX: assert non-empty first with '${dir:?dir is required}' so the expansion aborts instead of resolving to '/'."
}

rule bash-local-masks-exit-status {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "^\\s*(local|declare|readonly|export)\\s+[a-zA-Z_][a-zA-Z0-9_]*=\\$\\("
  MESSAGE "RISK: 'local x=$(cmd)' always returns 0 because 'local' itself succeeds, silently swallowing the subshell's failure even under 'set -e' (ShellCheck SC2155). FIX: split the declaration: 'local x; x=$(cmd)' so the assignment exit status propagates."
}

rule bash-cd-without-check {
  enabled true
  priority 70
  severity warning
  LOG write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "^\\s*cd\\s+[^|&;\\n]+$"
  MESSAGE "RISK: an unchecked 'cd' that fails leaves the script running in the wrong directory — subsequent 'rm', 'cp', or build commands then act on the parent's cwd (ShellCheck SC2164). FIX: chain failure handling: 'cd \"$dir\" || exit 1', or enable 'set -e' and quote the argument."
}

rule bash-heredoc-unquoted-delimiter {
  enabled true
  priority 75
  severity warning
  LOG write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "<<-?\\s*[A-Za-z_][A-Za-z0-9_]*\\s*$"
  MESSAGE "RISK: an unquoted heredoc delimiter ('<<EOF') expands $vars and $(cmd) inside the body — when the body contains untrusted text this becomes command injection. FIX: quote the opener ('<<\\'EOF\\'' or '<<\"EOF\"') whenever the body is meant to be literal."
}
