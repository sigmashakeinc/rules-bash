# bash_write_extra.rules
# Technology: bash | Capability: write

rule bash-warn-missing-strict-mode {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*.sh" AND content NOT CONTAINS "set -e" AND content NOT CONTAINS "set -euo pipefail"
  MESSAGE "Bash scripts should generally use 'set -e' or 'set -euo pipefail' to exit immediately if a command fails, preventing cascading errors."
}

rule bash-warn-unquoted-rm-rf {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*.sh" AND content LINE_REGEX "rm\\s+-r[fF]?\\s+\\$[a-zA-Z0-9_]+"
  MESSAGE "Using 'rm -rf' with an unquoted variable (e.g. rm -rf $DIR) can lead to catastrophic deletion if the variable is empty or contains spaces (resolving to 'rm -rf /' or similar). Always quote the variable: rm -rf \"$DIR\", and check if it is empty first."
}
