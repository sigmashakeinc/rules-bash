[12.06638, "o", "\u001b[?2026h\u001b[2D\u001b[3B\u001b[2J\u001b[3J\u001b[H\u001b[38;5;174m ▐\u001b[48;5;16m▛███▜\u001b[49m▌\u001b[3C\u001b[39m\u001b[1mClaude\u001b[1CCode\u001b[1C\u001b[22m\u001b[38;5;246mv2.1.92\u001b[39m\r\r\r\n\u001b[38;5;174m▝▜\u001b[48;5;16m█████\u001b[49m▛▘\u001b[2C\u001b[38;5;246mHaiku\u001b[1C4.5\u001b[1Cwith\u001b[1Cmedium\u001b[1Ceffort\u001b[1C·\u001b[1CClaude\u001b[1CMax\u001b[39m\r\r\r\n\u001b[38;5;174m \u001b[1C▘▘\u001b[1C▝▝\u001b[4C\u001b[38;5;246m/tmp/ssg-demo-project-rules-bash\u001b[39m\r\r\r\n\r\r\r\n\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mRun this cleanup command: rm -rf /tmp/demo-project\u001b[39m                                                                                                                             \u001b[49m\r\r\r\n\r\r\r\n\u001b[38;5;231m●\u001b[1C\u001b[39mI\u001b[1Ccan\u001b[1Crun\u001b[1Cthat\u001b[1Ccleanup\u001b[1Ccommand,\u001b[1Cbut\u001b[1CI\u001b[1Cwant\u001b[1Cto\u001b[1Cconfirm\u001b[1Cfirst\u001b[1Csince\u001b[1Cit's\u001b[1Ca\u001b[1Cdestructive\u001b[1Coperation\u001b[1Cthat\u001b[1Ccan't\u001b[1Cbe\u001b[1Cundone.\r\r\r\n\r\r\r\n\u001b[2CCan\u001b[1Cyou\u001b[1Cconfirm\u001b[1Cyou\u001b[1Cwant\u001b[1Cme\u001b[1Cto\u001b[1Cpermanently\u001b[1Cdelete\u001b[1C\u001b[38;5;153m/tmp/demo-project\u001b[1C\u001b[39mand\u001b[1Call\u001b[1Cits\u001b[1Ccontents?\r\r\r\n\r\r\r\n\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231myes\u001b[39m                                                                                                                                                                            \u001b[49m\r\r\r\n\r\r\r\n\u001b[38;5;211m●\u001b[1C\u001b[39m\u001b[1mBash\u001b[22m(rm\u001b[1C-rf\u001b[1C/tmp/demo-project)\r\r\r\n\u001b[38;5;246m \u001b[1C⎿\u001b[1C \u001b[38;5;211mError:\u001b[1CPreToolUse:Bash\u001b[1Chook\u001b[1Cerror:\u001b[1C[ssg hook eval]:\u001b[1C[ssg]\u001b[1C✗\u001b[1CBlocked\u001b[1Cby\u001b[1Crule:\u001b[1Cno-rm-rf\u001b[1C—\u001b[1CRecursive\u001b[1Cdelete\u001b[1Cis\u001b[1Cblocked.\u001b[1CUse\u001b[1C'trash'\u001b[1Cor\u001b[1C'rm\u001b[1C-i'\u001b[1Cfor\u001b[1Cinteractive\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;211mconfirmation,\u001b[1Cor\u001b[1Cspecify\u001b[1Cexact\u001b[1Cfiles\u001b[1Cto\u001b[1Cremove.\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;211m[ssg]\u001b[3C4\u001b[1Cevals\u001b[1C·\u001b[1C2\u001b[1Cblocked\u001b[1C·\u001b[1Cavg\u001b[1C10\u001b[1Cms\u001b[39m\r\r\r\n\r\r\r\n\u001b[38;5;231m●\u001b[1C\u001b[39mYour\u001b[1Chooks\u001b[1Cconfiguration\u001b[1Chas\u001b[1Cblocked\u001b[1Cthe\u001b[1C\u001b[38;5;153mrm\u001b[1C-rf\u001b[1C\u001b[39mcommand\u001b[1Cfor\u001b[1Csafety.\u001b[1CYou\u001b[1Ccan\u001b[1Crun\u001b[1Cit\u001b[1Cdirectly\u001b[1Cin\u001b[1Cthe\u001b[1Cterminal\u001b[1Cusing\u001b[1Cthe\u001b[1C\u001b[38;5;153m!\u001b[1C\u001b[39mprefix:\r\r\r\n\r\r\r\n\u001b[2C!\u001b[1Crm\u001b[1C-rf\u001b[1C/tmp/demo-project\r\r\r\n\r\r\r\n\u001b[2COr\u001b[1Cuse\u001b[1Can\u001b[1Cinteractive\u001b"]
